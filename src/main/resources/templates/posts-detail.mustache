{{>layout/header}}

<h1>게시글 상세</h1>
<div class="col-md-12">
    <div class="col-md-6">
        <div class="form-group mb-2">
            <label>글 번호</label>
            <input type="text" class="form-control" id="id" value="{{post.id}}" readonly>
        </div>
        <div class="form-group mb-2">
            <label>제목</label>
            <input type="text" class="form-control" value="{{post.title}}" readonly>
        </div>
        <div class="form-group mb-2">
            <label>작성자</label>
            <input type="text" class="form-control" value="{{post.author}}" readonly>
        </div>
        <div class="form-group mb-2">
            <label>내용</label>
            <textarea class="form-control" readonly>{{post.content}}</textarea>
        </div>
        <a href="/" role="button" class="btn btn-secondary">목록</a>
        <a href="/posts/update/{{post.id}}" role="button" class="btn btn-primary">수정</a>
    </div>
</div>

{{>layout/footer}}